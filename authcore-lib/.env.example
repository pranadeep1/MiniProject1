# Application
PORT=3000
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster-name>.mongodb.net/authcore?retryWrites=true&w=majority&appName=AuthCore
ACCESS_SECRET=access-secret-key-change-in-production
REFRESH_SECRET=refresh-secret-key-change-in-production

# SMTP (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
OTP_FROM_EMAIL=your_email@gmail.com

# OTP Security
OTP_TTL_MS=600000
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_VERIFY_LOCK_MS=600000
OTP_RESEND_COOLDOWN_MS=60000
