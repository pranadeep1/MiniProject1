{
  "name": "authcore",
  "version": "1.0.0",
  "description": "A reusable, stateless Node.js and Express library for authentication and Role-Based Access Control (RBAC).",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest",
    "lint": "eslint src/"
  },
  "keywords": [
    "auth",
    "jwt",
    "rbac",
    "express",
    "middleware",
    "mongodb",
    "mongoose"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
